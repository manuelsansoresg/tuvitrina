generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum Role {
  USER
  ADMIN
}

enum PlanType {
  EXPRESS
  EMPRENDEDOR
  PREMIUM
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  name            String?
  password        String
  role            Role           @default(USER)
  plan            PlanType       @default(EXPRESS)
  active          Boolean        @default(true)
  subscriptionEnd DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  businessCard    BusinessCard?
  subscriptions   Subscription[]
}

model BusinessCard {
  id          String   @id @default(cuid())
  slug        String   @unique
  logoUrl     String?
  bannerUrl   String?
  title       String
  description String?
  themeColor  String?  @default("#000000")
  location    String?  // Google Maps Embed URL or coordinates
  active      Boolean  @default(true)
  
  // Customization
  cardBackgroundColor String? @default("#ffffff")
  cardBackgroundImage String?
  titleColor          String? @default("#0f172a") // slate-900
  descriptionColor    String? @default("#64748b") // slate-500
  iconColor           String? // Custom icon color, null = brand colors
  galleryTitleColor   String? @default("#ffffff") // Default white for gallery overlay
  galleryPriceColor   String? @default("#4ade80") // Default green-400 for gallery overlay
  linkTextColor       String? @default("#0f172a") // Text color for links
  linkBackgroundColor String? @default("#ffffff") // Background color for links
  linkBorderColor     String? @default("#e2e8f0") // Border color for links

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  links       Link[]
  gallery     GalleryImage[]
  products    Product[]
}

model Link {
  id        String       @id @default(cuid())
  icon      String       // Store icon name (e.g., from lucide-react)
  label     String
  url       String
  order     Int          @default(0)
  
  cardId    String
  card      BusinessCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model GalleryImage {
  id        String       @id @default(cuid())
  imageUrl  String
  title     String?
  price     Float?
  order     Int          @default(0)
  
  cardId    String
  card      BusinessCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model Product {
  id          String       @id @default(cuid())
  title       String
  description String?
  price       Float?
  imageUrl    String?
  order       Int          @default(0)
  
  cardId      String
  card        BusinessCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model Subscription {
  id        String   @id @default(cuid())
  paymentId String?  @unique // Mercado Pago Payment ID
  amount    Float
  currency  String   @default("MXN")
  status    String   // active, canceled, expired
  startDate DateTime @default(now())
  endDate   DateTime
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
